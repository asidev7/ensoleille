# Copiez ce fichier vers .env et adaptez les valeurs.
SECRET_KEY=changez-moi-en-production-avec-une-cle-secrete-longue
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Base de données.
# Laissez vide pour utiliser SQLite (dev). Pour PostgreSQL :
# DATABASE_URL=postgres://user:password@localhost:5432/ensoleille
DATABASE_URL=

# Email (contact / newsletter) — console en dev.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
